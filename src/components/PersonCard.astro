---
export interface Props {
  name: string;
  title: string;
  company: string;
  description: string;
  image?: string;
  category: 'business' | 'academic';
}

const { name, title, company, description, image, category } = Astro.props;
const gradient = category === 'business'
  ? 'from-primary-500/20 to-accent-500/20'
  : 'from-purple-500/20 to-indigo-500/20';
---

<div class="glass-card overflow-hidden group">
  <div class={`aspect-[4/3] bg-gradient-to-br ${gradient} flex items-center justify-center relative`}>
    {image ? (
      <img src={image} alt={name} class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <div class="text-center p-6">
        <div class="w-20 h-20 mx-auto rounded-full bg-white/10 flex items-center justify-center mb-3">
          <span class="text-3xl font-bold gradient-text">{name.charAt(0)}</span>
        </div>
        <span class="text-xs uppercase tracking-wider text-gray-500">
          {category === 'business' ? '商业领域' : '学术领域'}
        </span>
      </div>
    )}
  </div>
  <div class="p-5">
    <div class="flex items-center gap-1 mb-1">
      <span class={`text-xs px-2 py-0.5 rounded-full ${
        category === 'business'
          ? 'bg-primary-500/10 text-primary-600'
          : 'bg-purple-500/10 text-purple-600'
      }`}>
        {category === 'business' ? '💼 商业' : '🎓 学术'}
      </span>
    </div>
    <h3 class="text-lg font-bold text-gray-900">{name}</h3>
    <p class="text-sm text-primary-600">{title}</p>
    <p class="text-xs text-gray-500 mb-2">{company}</p>
    <p class="text-sm text-gray-500 leading-relaxed">{description}</p>
  </div>
</div>
