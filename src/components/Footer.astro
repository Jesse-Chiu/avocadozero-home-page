---
import { path } from '../utils/base';
import pkg from '../../package.json';

const buildTime = new Date().toISOString().replace('T', ' ').slice(0, 19);
const version = `v${pkg.version} · ${buildTime}`;
---

<footer class="bg-gradient-to-b from-green-50/50 via-white to-white border-t border-green-100/60">
  <!-- CTA Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="glass-card p-8 md:p-12 text-center relative overflow-hidden bg-gradient-to-br from-blue-50 to-cyan-50">
      <div class="relative z-10">
        <h2 class="text-2xl md:text-3xl font-bold mb-4 text-gray-900">
          准备好开启信息学之旅了吗？
        </h2>
        <p class="text-gray-500 mb-8 max-w-xl mx-auto">
          不确定是否适合学？想了解课程详情？欢迎联系我们，免费获取学习规划建议。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={path('/about#contact')} class="btn-primary">
            联系我们
          </a>
          <a href={path('/curriculum')} class="btn-ghost">
            查看课程体系
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-200 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-gray-500 text-sm">
          <span class="text-2xl">🥑</span>
          <div class="flex flex-col items-center leading-tight">
            <span class="font-bold text-lg text-green-700">牛油果零壹信奥</span>
            <span class="text-[11px] tracking-widest text-green-600 font-medium">Avocado Zero Olympiad</span>
          </div>
          <span class="ml-1">&copy; {new Date().getFullYear()}</span>
        </div>
        <div class="flex items-center gap-6 text-sm text-gray-500">
          <a href={path('/about')} class="hover:text-gray-700 transition-colors">关于我们</a>
          <a href={path('/about#contact')} class="hover:text-gray-700 transition-colors">联系方式</a>
          <span class="hidden sm:inline">关注公众号获取更多信息学资讯</span>
          <!-- Visitor Counter -->
          <div id="visitor-counter" class="flex items-center gap-1.5 text-gray-400 text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span id="visitor-count" class="tabular-nums">...</span>
            <span>次访问</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Version Info -->
  <div class="border-t border-gray-100 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[11px] text-gray-400 tabular-nums font-mono tracking-tight">{version}</span>
    </div>
  </div>

  <!-- Busuanzi hidden data targets -->
  <span id="busuanzi_container_site_pv" style="display:none">
    <span id="busuanzi_value_site_pv"></span>
  </span>

  <!-- Busuanzi (web analytics) -->
  <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

  <!-- Visitor Counter: bridge busuanzi data → our UI -->
  <script type="text/javascript">
    (function () {
      var countEl = document.getElementById('visitor-count');
      var bsEl = document.getElementById('busuanzi_value_site_pv');
      if (!countEl || !bsEl) return;

      function animateCount(el, target) {
        var duration = 800;
        var start = 0;
        var startTime = performance.now();

        function step(now) {
          var elapsed = now - startTime;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var current = Math.floor(start + (target - start) * eased);
          el.textContent = current.toLocaleString();
          if (progress < 1) {
            requestAnimationFrame(step);
          }
        }

        requestAnimationFrame(step);
      }

      function tryShowCount() {
        var val = parseInt(bsEl.textContent || '', 10);
        if (val > 0) {
          countEl.textContent = '';
          animateCount(countEl, val);
          return true;
        }
        return false;
      }

      // MutationObserver: watch for busuanzi to fill in the value
      var observer = new MutationObserver(function () {
        tryShowCount();
      });
      observer.observe(bsEl, { childList: true, characterData: true, subtree: true });

      // Fallback: poll for up to 8 seconds
      var attempts = 0;
      var timer = setInterval(function () {
        attempts++;
        if (tryShowCount() || attempts >= 40) {
          clearInterval(timer);
          if (attempts >= 40) {
            countEl.textContent = '-';
          }
        }
      }, 200);
    })();
  </script>
</footer>
