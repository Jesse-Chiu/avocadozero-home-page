---
export interface Props {
  title?: string;
  description?: string;
  primaryText?: string;
  primaryLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
}

const {
  title = '准备好了吗？',
  description = '加入信息学奥赛训练，从这里开始改变。',
  primaryText = '联系我们',
  primaryLink = '/about#contact',
  secondaryText = '了解更多',
  secondaryLink = '/about-cs',
} = Astro.props;
---

<section class="py-20 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto text-center">
  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">{title}</h2>
  <p class="text-gray-500 mb-8">{description}</p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center">
    <a href={primaryLink} class="btn-primary">{primaryText}</a>
    <a href={secondaryLink} class="btn-ghost">{secondaryText}</a>
  </div>
</section>
