---
import { path } from '../utils/base';

const navItems = [
  { label: '首页', href: '/' },
  { label: '什么是信息学', href: '/about-cs' },
  { label: '课程体系', href: '/curriculum' },
  { label: '学信息学有什么用', href: '/benefits' },
  { label: '升学帮助', href: '/admission' },
  { label: '成功案例', href: '/success' },
  { label: '关于我们', href: '/about' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gradient-to-r from-green-50/95 via-white/90 to-emerald-50/95 backdrop-blur-xl border-b border-green-100/60 shadow-[0_1px_4px_rgba(0,0,0,0.05)]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={path('/')} class="flex items-center gap-2 group py-1">
        <span class="text-2xl">🥑</span>
        <div class="flex flex-col items-center leading-tight">
          <span class="font-bold text-lg tracking-tight text-green-700 group-hover:text-green-600 transition-colors">牛油果零壹信奥</span>
          <span class="text-[11px] tracking-widest text-green-600 font-medium">Avocado Zero Olympiad</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={path(item.href)}
            class="relative px-3.5 py-2 rounded-full text-sm font-medium text-gray-600
                   border border-gray-200/80 bg-white/60
                   hover:text-green-700 hover:border-green-300 hover:bg-green-50/70
                   hover:shadow-sm hover:-translate-y-0.5
                   active:translate-y-0 active:shadow-none
                   transition-all duration-200"
          >
            {item.label}
          </a>
        ))}
        <a href={path('/about#contact')}
           class="ml-2 px-4 py-2 rounded-full text-sm font-semibold text-white
                  bg-gradient-to-r from-green-500 to-emerald-500
                  hover:from-green-600 hover:to-emerald-600
                  hover:shadow-md hover:shadow-green-200 hover:-translate-y-0.5
                  active:translate-y-0 active:shadow-sm
                  transition-all duration-200">
          联系我们
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 rounded-lg text-gray-600 hover:text-green-700 hover:bg-green-50/60 transition-colors"
        aria-label="菜单"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4 border-t border-gray-200/60 mt-2 pt-3">
      <div class="flex flex-col gap-1.5">
        {navItems.map((item) => (
          <a
            href={path(item.href)}
            class="px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 text-center
                   border border-gray-200/80 bg-white/70
                   hover:text-green-700 hover:border-green-300 hover:bg-green-50/70
                   transition-all duration-200"
          >
            {item.label}
          </a>
        ))}
        <a href={path('/about#contact')} class="btn-primary text-sm mt-1 justify-center">
          联系我们
        </a>
      </div>
    </div>
  </nav>
</header>

<!-- Offset for fixed header -->
<div class="h-16"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
