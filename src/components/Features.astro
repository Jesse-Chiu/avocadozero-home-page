---
export interface Feature {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  features: Feature[];
}
---

<section class="py-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  {Astro.props.title && (
    <h2 class="section-title">{Astro.props.title}</h2>
  )}
  {Astro.props.subtitle && (
    <p class="section-subtitle">{Astro.props.subtitle}</p>
  )}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {Astro.props.features.map((feature) => (
      <div class="glass-card p-6 text-center group">
        <div class="text-4xl mb-4 inline-block group-hover:scale-110 transition-transform duration-300">
          {feature.icon}
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">
          {feature.title}
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          {feature.description}
        </p>
      </div>
    ))}
  </div>
</section>
